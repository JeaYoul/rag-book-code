# docker-compose.yml — PostgreSQL(pgvector) + MongoDB 두 그릇을 띄운다
#
# 11장 "설치하고, DB를 만들고, 테이블을 만든다" 참고.
# 9장에서 배운 도커로, 두 DB를 컨테이너로 격리해 띄운다. 죽어도 restart로 되살아난다.
#
# 실행:
#   cp config.example.env .env   # 먼저 비밀번호 채우기
#   docker compose up -d
#   docker compose ps
#
# ⚠️ .env 의 비밀번호를 커밋하지 마세요.

services:

  postgres:
    image: pgvector/pgvector:pg16      # pgvector가 포함된 PostgreSQL
    container_name: rag-postgres
    restart: unless-stopped            # 죽어도 되살아난다 (불사조의 값싼 버전)
    env_file: .env
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data

  mongodb:
    image: mongo:7
    container_name: rag-mongo
    restart: unless-stopped
    env_file: .env
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_USER}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASSWORD}
    ports:
      - "27017:27017"
    volumes:
      - mongodata:/data/db

volumes:
  pgdata:
  mongodata:
