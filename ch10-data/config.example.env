# config.example.env — 복사해서 .env 로 쓰세요 (cp config.example.env .env)
#
# ⚠️ .env 는 절대 커밋하지 마세요. .gitignore 에 넣으세요.

# NCBI Entrez는 이메일 등록을 요구합니다 (연락처 용도).
NCBI_EMAIL=<당신의_이메일@example.com>

# API 키가 있으면 속도 제한이 완화됩니다 (3req/s → 10req/s).
# 없으면 비워둬도 동작은 합니다 (더 느릴 뿐).
# 발급: NCBI 계정 → Settings → API Key Management
NCBI_API_KEY=<선택: NCBI_API_KEY_또는_비움>

# 요청 간격(초). API 키 없으면 0.34 이상 권장, 있으면 0.11 이상.
REQUEST_INTERVAL=0.34

# 데이터 저장 루트
DATA_ROOT=./data
LIST_ROOT=./lists
